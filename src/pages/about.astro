---
import Layout from '@/layouts/Layout.astro';
import { SITE } from '@/config';
import Breadcrumbs from '@/components/Breadcrumbs.svelte';
import { render, getEntry } from 'astro:content';
import { getBreadcrumbSchema } from '@/lib/schemas';

const schema = getBreadcrumbSchema([
  { name: 'About', url: new URL('/about', Astro.site).toString() },
]);
import { Image } from 'astro:assets';
import profilePhoto from '@/site-assets/profile_photo.png';

// Social icons mapping
const socialIcons: Record<string, string> = {
  github:
    '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  linkedin:
    '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
  bluesky:
    '<path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/>',
  mastodon:
    '<path d="M21.327 8.566c0-4.339-2.843-5.61-2.843-5.61-1.433-.658-3.894-.935-6.451-.956h-.063c-2.557.021-5.016.298-6.45.956 0 0-2.843 1.272-2.843 5.61 0 .993-.019 2.181.012 3.441.103 4.243.778 8.425 4.701 9.463 1.809.479 3.362.579 4.612.51 2.268-.126 3.541-.809 3.541-.809l-.075-1.646s-1.621.511-3.441.449c-1.804-.062-3.707-.194-3.999-2.409a4.523 4.523 0 0 1-.04-.621s1.77.433 4.014.536c1.372.063 2.658-.08 3.965-.236 2.506-.299 4.688-1.843 4.962-3.254.434-2.223.398-5.424.398-5.424zm-3.353 5.59h-2.081V9.057c0-1.075-.452-1.62-1.357-1.62-1 0-1.501.647-1.501 1.927v2.791h-2.069V9.364c0-1.28-.501-1.927-1.502-1.927-.905 0-1.357.545-1.357 1.62v5.099H6.026V8.903c0-1.074.273-1.927.823-2.558.566-.631 1.307-.955 2.228-.955 1.065 0 1.872.409 2.405 1.228l.518.869.519-.869c.533-.819 1.34-1.228 2.4-1.228.92 0 1.662.324 2.228.955.549.631.822 1.484.822 2.558v5.253z"/>',
  email:
    '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  website:
    '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>',
};

// Get icon for social platform
function getSocialIcon(name: string): string {
  const lowercaseName = name.toLowerCase();
  return socialIcons[lowercaseName as keyof typeof socialIcons] || socialIcons.website;
}

const aboutPost = await getEntry('about', 'index');
const { Content } = aboutPost ? await render(aboutPost) : { Content: null };
const aboutTitle =
  aboutPost?.data.title || `I'm ${SITE.author}, a software designer and entrepreneur.`;
---

<Layout
  title={`About | ${SITE.author}`}
  description={`Learn more about ${SITE.author}, a developer and designer focused on building premium web experiences.`}
  schema={schema}
>
  <Breadcrumbs items={[{ name: 'About', href: '/about' }]} />

  <div class="flex flex-col lg:flex-row gap-8 lg:gap-10">
    <!-- Left Sidebar: Profile + Social -->
    <aside class="flex-shrink-0 lg:w-64 space-y-6">
      <!-- Profile Photo -->
      <div class="w-full aspect-square">
        <Image
          src={profilePhoto}
          alt={SITE.author}
          width={400}
          height={400}
          widths={[200, 400, 800]}
          sizes="(max-width: 1024px) 100vw, 256px"
          class="w-full h-full object-cover rounded-2xl border-2 border-border shadow-xl"
        />
      </div>

      <!-- Connect Section -->
      <div>
        <h2 class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-3">
          Connect
        </h2>
        <div class="space-y-1">
          {
            Object.entries(SITE.social).map(([name, url]) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2.5 px-2.5 py-2 rounded-lg hover:bg-accent transition-all group no-underline"
              >
                <div class="h-8 w-8 rounded-lg bg-secondary flex items-center justify-center text-muted-foreground group-hover:bg-primary group-hover:text-primary-foreground transition-all flex-shrink-0">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={getSocialIcon(name)}
                  />
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-sm text-foreground capitalize leading-tight">
                    {name}
                  </div>
                </div>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-muted-foreground group-hover:text-primary transition-colors flex-shrink-0"
                >
                  <path d="M7 7h10v10" />
                  <path d="M7 17 17 7" />
                </svg>
              </a>
            ))
          }
        </div>
      </div>
    </aside>

    <!-- Right Content: Bio -->
    <div class="flex-1 min-w-0">
      <h1
        class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-foreground leading-[1.1] mb-6"
      >
        {aboutTitle}
      </h1>
      <article class="prose max-w-none text-muted-foreground">
        {Content ? <Content /> : <p>Loading content...</p>}
      </article>
    </div>
  </div>
</Layout>
